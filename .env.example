# Server
PORT=3000
API_KEY=your_api_key_here

# EPOS Now API (default for all stores — override per-store in DB)
EPOS_API_URL=https://api.eposnowhq.com/api/v4
EPOS_API_TOKEN=your_epos_api_token_here

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=epos_woo_sync

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Sync Configuration
SYNC_DIRECTION=EPOS_TO_WOO
SYNC_INTERVAL_MINUTES=10
BATCH_SIZE=20
DRY_RUN=false

# Webhooks
WEBHOOK_SECRET=your_epos_webhook_secret_here
WOO_WEBHOOK_SECRET=your_woo_webhook_secret_here

# Logging
LOG_DIR=./logs
LOG_LEVEL=info
