{
  "name": "epos-woo-sync",
  "version": "4.0.0",
  "description": "Multi-store product synchronization between EPOS Now and WooCommerce",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node src/app.js",
    "worker": "node src/sync/sync.worker.js",
    "sync:once": "node src/run-once.js",
    "sync:dry": "DRY_RUN=true node src/run-once.js",
    "db:init": "node src/db/init.js",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "mysql2": "^3.6.0",
    "node-cron": "^3.0.0",
    "nodemailer": "^6.10.1"
  }
}
